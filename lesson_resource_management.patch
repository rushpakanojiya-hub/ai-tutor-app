+// --- Lesson Resource Management (additive) ---
+
+// ErrNoResourcesYet is returned when trying to publish a lesson that has
+// no video (uploaded or YouTube) and no PDF yet.
+var ErrNoResourcesYet = errors.New("add at least one video or PDF before publishing")
+
+// Publish marks a lesson as published, but only once it actually has a
+// video or a PDF - an empty lesson going live would show students a
+// blank screen.
+func (s *Service) Publish(id int) error {
+	lesson, err := s.repo.FindByID(id)
+	if err != nil {
+		return err
+	}
+	hasVideo := lesson.VideoURL != "" || lesson.YouTubeURL != ""
+	hasPDF := lesson.PDFURL != ""
+	if !hasVideo && !hasPDF {
+		return ErrNoResourcesYet
+	}
+	return s.repo.SetStatus(id, StatusPublished)
+}
+
+// Unpublish reverts a lesson back to draft - always allowed.
+func (s *Service) Unpublish(id int) error {
+	return s.repo.SetStatus(id, StatusDraft)
+}
+
+// SetYouTubeVideo points a lesson's video at a YouTube URL instead of an
+// uploaded file.
+func (s *Service) SetYouTubeVideo(id int, url string) error {
+	if url == "" {
+		return errors.New("a YouTube URL is required")
+	}
+	return s.repo.SetYouTubeURL(id, url)
+}
+
+// RemoveVideo clears whichever video (uploaded or YouTube) a lesson has.
+func (s *Service) RemoveVideo(id int) error {
+	return s.repo.ClearVideo(id)
+}
+
+// RemovePDF clears a lesson's PDF file along with its title/description.
+func (s *Service) RemovePDF(id int) error {
+	return s.repo.ClearPDF(id)
+}
+
 func (s *Service) Reorder(items []ReorderItem) error {
 	return s.repo.Reorder(items)
 }
diff --git a/backend/migrations/027_lesson_resource_management.sql b/backend/migrations/027_lesson_resource_management.sql
new file mode 100644
index 0000000..d980f00
--- /dev/null
+++ b/backend/migrations/027_lesson_resource_management.sql
@@ -0,0 +1,18 @@
+-- Lesson Resource Management: lessons need their own publish/draft
+-- lifecycle (independent of the parent subject's status - a subject can
+-- be published while individual lessons inside it are still being
+-- prepared), richer PDF metadata (title/description shown to students
+-- alongside the file), and support for YouTube-hosted videos as an
+-- alternative to the existing Cloudinary-uploaded video_url.
+
+BEGIN;
+
+ALTER TABLE lessons ADD COLUMN IF NOT EXISTS status VARCHAR(20) NOT NULL DEFAULT 'draft';
+ALTER TABLE lessons ADD COLUMN IF NOT EXISTS pdf_title VARCHAR(255);
+ALTER TABLE lessons ADD COLUMN IF NOT EXISTS pdf_description TEXT;
+ALTER TABLE lessons ADD COLUMN IF NOT EXISTS video_source VARCHAR(20) NOT NULL DEFAULT 'upload';
+ALTER TABLE lessons ADD COLUMN IF NOT EXISTS youtube_url TEXT;
+
+CREATE INDEX IF NOT EXISTS idx_lessons_status ON lessons(status);
+
+COMMIT;
