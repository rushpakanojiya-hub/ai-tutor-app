--- /dev/null
+++ b/backend/migrations/027_lesson_resource_management.sql
@@ -0,0 +1,23 @@
+-- Lesson Resource Management workflow support.
+--
+-- Mirrors the exact pattern already used for subjects.status
+-- (see 025_add_course_management.sql): lessons need their own
+-- draft/published lifecycle, independent of the subject's.
+--
+-- Existing lessons default to 'published' so this migration does not
+-- change what students already see. New lessons created through the
+-- updated Create/Edit Lesson flow explicitly start as 'draft' at the
+-- application layer (see internal/lessons/repository.go Create()).
+--
+-- notes.description is additive metadata for the "PDF Notes" section
+-- of the Lesson page (Title + Description alongside the PDF itself);
+-- existing notes simply get an empty description.
+
+BEGIN;
+
+ALTER TABLE lessons ADD COLUMN IF NOT EXISTS status VARCHAR(20) NOT NULL DEFAULT 'published';
+CREATE INDEX IF NOT EXISTS idx_lessons_status ON lessons(status);
+
+ALTER TABLE notes ADD COLUMN IF NOT EXISTS description TEXT;
+
+COMMIT;
