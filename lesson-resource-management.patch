+	query := `
+		SELECT (COALESCE(video_url, '') != '' OR COALESCE(pdf_url, '') != '')
+		FROM lessons WHERE id = $1
+	`
+	err := r.db.QueryRow(query, id).Scan(&has)
+	if err == sql.ErrNoRows {
+		return false, ErrLessonNotFound
+	}
+	return has, err
+}
