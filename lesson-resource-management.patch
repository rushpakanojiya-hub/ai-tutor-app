+
+// --- Lesson Resource Management (additive) ---
+
+// Publish enforces "at least one learning resource (video or PDF) is
+// required before publishing" - mirrors subjects.Service.Publish's
+// "at least one lesson" rule at the level below it.
+func (s *Service) Publish(id int) error {
+	hasResource, err := s.repo.HasResource(id)
+	if err != nil {
+		return err
+	}
+	if !hasResource {
+		return ErrNoResourceYet
+	}
+	return s.repo.SetStatus(id, StatusPublished)
+}
+
+// Unpublish always succeeds - a lesson can go back to draft regardless
+// of what resources it has (matches subjects.Service.Unpublish).
+func (s *Service) Unpublish(id int) error {
+	return s.repo.SetStatus(id, StatusDraft)
+}
+
+// isYouTubeURL is a light heuristic, not a strict validator - it only
+// needs to reject obviously-wrong input before it's stored as a
+// lesson's video_url.
+func isYouTubeURL(url string) bool {
+	lower := strings.ToLower(strings.TrimSpace(url))
+	return strings.HasPrefix(lower, "http://") || strings.HasPrefix(lower, "https://")
+}
+
+// SetYouTubeURL stores a manually-entered YouTube link as the lesson's
+// video, the alternative to UploadVideo. Reuses the same video_url
+// column/repo method - the frontend tells uploaded-file vs YouTube apart
+// by URL shape, nothing server-side needs to distinguish them.
+func (s *Service) SetYouTubeURL(lessonID int, url string) error {
+	url = strings.TrimSpace(url)
+	if url == "" || !isYouTubeURL(url) {
+		return errors.New("a valid YouTube URL is required")
+	}
+	return s.repo.SetVideoURL(lessonID, url)
+}
+
+// RemoveVideo clears whichever video (uploaded or YouTube) is set.
+func (s *Service) RemoveVideo(lessonID int) error {
+	return s.repo.SetVideoURL(lessonID, "")
+}
+
+// RemovePDF clears the lesson's PDF url. The corresponding notes row
+// (title/description) is removed separately by the notes package.
+func (s *Service) RemovePDF(lessonID int) error {
+	return s.repo.SetPDFURL(lessonID, "")
+}
