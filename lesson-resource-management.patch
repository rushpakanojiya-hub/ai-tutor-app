+                    ),
+                    const SizedBox(width: 12),
+                    Expanded(
+                      child: FilledButton.icon(
+                        onPressed: _lesson!.isPublished ? null : _publish,
+                        icon: const Icon(Icons.publish_rounded, size: 18),
+                        label: Text(_lesson!.isPublished ? 'Published' : 'Publish'),
+                      ),
+                    ),
+                  ],
+                ),
+                if (_lesson!.isPublished) ...[
+                  const SizedBox(height: 8),
+                  Align(
+                    alignment: Alignment.centerLeft,
+                    child: TextButton.icon(
+                      onPressed: () async {
+                        setState(() => _busyStatus = true);
+                        try {
+                          await _service.unpublishLesson(_lesson!.id);
+                          await _refreshLesson();
+                        } catch (_) {
+                          _snack('Failed to unpublish.');
+                        } finally {
+                          if (mounted) setState(() => _busyStatus = false);
