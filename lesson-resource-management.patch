+// --- Lesson Resource Management (additive) ---
+
+// Update applies only the provided (non-nil) fields - same COALESCE
+// convention as lessons.Repository.Update.
+func (r *Repository) Update(id int, req UpdateNoteRequest) error {
+	res, err := r.db.Exec(`
+		UPDATE notes SET
+			title = COALESCE($1, title),
+			description = COALESCE($2, description),
+			pdf_url = COALESCE($3, pdf_url)
+		WHERE id = $4`,
+		req.Title, req.Description, req.PDFURL, id,
+	)
+	if err != nil {
+		return err
+	}
+	rows, _ := res.RowsAffected()
+	if rows == 0 {
+		return ErrNoteNotFound
+	}
+	return nil
+}
+
+// Delete removes a single note (the "Remove PDF" action).
+func (r *Repository) Delete(id int) error {
+	res, err := r.db.Exec(`DELETE FROM notes WHERE id = $1`, id)
+	if err != nil {
+		return err
+	}
+	rows, _ := res.RowsAffected()
+	if rows == 0 {
+		return ErrNoteNotFound
+	}
+	return nil
+}
